{
  "name": "sony-lens-manager",
  "version": "1.0.0",
  "description": "Sony RAW Lens Metadata Manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:mac:arm64": "electron-builder --mac --arm64",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.18.0",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.sony-lens-manager.app",
    "productName": "Sony Lens Manager",
    "mac": {
      "category": "public.app-category.photography",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "files": [
      "**/*",
      "git-service.js",
      "!dist/**",
      "!uploads/**",
      "!processed/**",
      "!previews/**",
      "!*.dmg",
      "!*.zip"
    ],
    "asarUnpack": [
      "git-service.js",
      "lenses.json",
      "server.js",
      "lens-data-repo/**",
      "node_modules/sharp/**",
      "node_modules/@img/**"
    ],
    "extraResources": [
      {
        "from": "git-service.js",
        "to": "git-service.js"
      },
      {
        "from": "lenses.json",
        "to": "lenses.json"
      },
      {
        "from": "lens-data-repo",
        "to": "lens-data-repo"
      },
      {
        "from": "node_modules/sharp",
        "to": "node_modules/sharp"
      },
      {
        "from": "node_modules/@img",
        "to": "node_modules/@img"
      }
    ]
  }
}