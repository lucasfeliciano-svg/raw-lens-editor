{
  "name": "sony-lens-manager",
  "version": "1.0.0",
  "description": "Sony RAW Lens Metadata Manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:mac:arm64": "electron-builder --mac --arm64",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.18.0",
    "sharp": "^0.33.0"
  },
  "build": {
    "appId": "com.sony.lensmanager",
    "productName": "Sony Lens Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "package.json",
      "lenses.json",
      "public/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "node_modules/express/**/*",
      "node_modules/cors/**/*",
      "node_modules/multer/**/*",
      "node_modules/body-parser/**/*"
    ],
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.photography",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    }
  }
}
