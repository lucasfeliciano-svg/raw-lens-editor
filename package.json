{
  "name": "sony-lens-manager",
  "version": "1.0.0",
  "description": "Sony RAW Lens Metadata Manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:mac:arm64": "electron-builder --mac --arm64",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "canvas": "^3.2.3",
    "cors": "^2.8.5",
    "exiftool": "^0.0.3",
    "exiftool-vendored": "^34.3.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.0"
  },
  "build": {
    "appId": "com.sony.lensmanager",
    "productName": "Sony Lens Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "package.json",
      "lenses.json",
      "public/**/*",
      "public/index.html",
      "public/style.css",
      "public/script.js",
      "public/lens-manager.html",
      "public/lens-manager.js",
      "public/lens-manager.css",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      },
      {
        "from": "lenses.json",
        "to": "lenses.json"
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.photography",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/exiftool-vendored/**/*",
      "**/node_modules/sharp/**/*",
      "**/node_modules/canvas/**/*",
      "node_modules/exiftool-vendored/**/*"
    ]
  }
}
